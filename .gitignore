# Dependencies
node_modules/
.npm-cache/
# Build output
dist/

# Local data & auth
store/
data/
logs/

# Groups - ignore all contents, whitelist CLAUDE.md and global skills/
# Step 1: ignore everything inside every group
groups/**
# Step 2: re-allow traversal into group subdirs (required for negation to work)
!groups/*/
# Step 3: whitelist the files we want tracked
!groups/**/CLAUDE.md
!groups/global/skills/
!groups/global/skills/**
 
# Secrets
*.keys.json
*.apps.googleusercontent.com.json
.env

# Temp files
.tmp-*

# OS
.DS_Store

# IDE
.idea/
.vscode/

# Skills system (local per-installation state)
.nanoclaw/

agents-sdk-docs

# TLS certs (Tailscale Funnel)
*.crt
*.key
*.pem
