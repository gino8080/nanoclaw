{
  "name": "nanoclaw",
  "version": "1.2.12",
  "description": "Personal Claude assistant. Lightweight, secure, customizable.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "husky",
    "setup": "tsx setup/index.ts",
    "auth": "tsx src/whatsapp-auth.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "logs": "bash scripts/logs.sh",
    "logs:status": "bash scripts/logs.sh status",
    "logs:host": "bash scripts/logs.sh host",
    "logs:agents": "bash scripts/logs.sh agents",
    "logs:pool": "bash scripts/logs.sh pool",
    "logs:errors": "bash scripts/logs.sh errors",
    "reload": "npm run build && (launchctl kickstart -k gui/$(id -u)/com.nanoclaw || launchctl load ~/Library/LaunchAgents/com.nanoclaw.plist) && echo '✓ NanoClaw rebuilt and restarted'",
    "stop": "launchctl bootout gui/$(id -u)/com.nanoclaw 2>/dev/null; echo '✓ NanoClaw stopped'"
  },
  "dependencies": {
    "@types/qrcode-terminal": "^0.12.0",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "better-sqlite3": "^11.8.1",
    "cron-parser": "^5.5.0",
    "dotenv": "^17.3.1",
    "grammy": "^1.39.3",
    "marked": "^17.0.4",
    "openai": "^6.27.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.0.18",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}
